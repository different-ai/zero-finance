// SPDX-License-Identifier: MIT
pragma solidity ^0.8.23;

import {IERC20} from "forge-std/interfaces/IERC20.sol";
import {IERC4626} from "forge-std/interfaces/IERC4626.sol";
import {SafeERC20} from "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";

/**
 * @title CrossChainVaultReceiver
 * @notice Receives USDC from Across Protocol and deposits into Morpho vaults
 * @dev Deployed on destination chain (Arbitrum)
 * @author 0 Finance
 * 
 * Flow:
 * 1. User initiates deposit on Base via CrossChainVaultManager
 * 2. Across bridges USDC to this contract on Arbitrum
 * 3. This contract receives callback from Across with message data
 * 4. Deposits USDC into specified Morpho vault
 * 5. Vault shares are minted directly to user's Safe on Arbitrum
 */
contract CrossChainVaultReceiver {
    using SafeERC20 for IERC20;

    /// @notice Across SpokePool address on Arbitrum
    address public immutable ACROSS_SPOKE_POOL;
    
    /// @notice Contract owner (for emergency functions)
    address public owner;
    
    /// @notice Mapping of allowed vaults (for security)
    mapping(address => bool) public allowedVaults;
    
    /// @notice Emitted when a cross-chain deposit is completed
    event CrossChainDepositComplete(
        address indexed userSafe,
        address indexed vaultAddress,
        uint256 assetsDeposited,
        uint256 sharesReceived,
        bytes32 indexed messageId
    );
    
    /// @notice Emitted when a vault's allowed status changes
    event VaultAllowed(address indexed vaultAddress, bool allowed);
    
    /// @notice Emitted when ownership is transferred
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    
    /// @notice Only Across SpokePool can call
    error UnauthorizedCaller();
    
    /// @notice Vault is not in the allowlist
    error VaultNotAllowed();
    
    /// @notice Insufficient shares received (slippage protection)
    error InsufficientShares();
    
    /// @notice Invalid parameters
    error InvalidParameters();
    
    /**
     * @notice Constructor
     * @param _acrossSpokePool Across SpokePool address on this chain
     * @param _owner Initial owner address
     */
    constructor(address _acrossSpokePool, address _owner) {
        if (_acrossSpokePool == address(0) || _owner == address(0)) {
            revert InvalidParameters();
        }
        ACROSS_SPOKE_POOL = _acrossSpokePool;
        owner = _owner;
    }
    
    /// @notice Restrict to Across SpokePool
    modifier onlyAcross() {
        if (msg.sender != ACROSS_SPOKE_POOL) revert UnauthorizedCaller();
        _;
    }
    
    /// @notice Restrict to owner
    modifier onlyOwner() {
        if (msg.sender != owner) revert UnauthorizedCaller();
        _;
    }
    
    /**
     * @notice Called by Across SpokePool when cross-chain message is relayed
     * @dev This is the V3 interface used by Across
     * @param tokenSent The token received (USDC)
     * @param amount Amount of tokens received
     * @param relayer Address that relayed the message (unused)
     * @param message Encoded call data: (userSafe, vaultAddress, minSharesOut)
     */
    function handleV3AcrossMessage(
        address tokenSent,
        uint256 amount,
        address relayer,
        bytes memory message
    ) external onlyAcross {
        // Decode the message from Base
        (address userSafe, address vaultAddress, uint256 minSharesOut) = 
            abi.decode(message, (address, address, uint256));
        
        // Security: only allow whitelisted vaults
        if (!allowedVaults[vaultAddress]) revert VaultNotAllowed();
        
        // Validate parameters
        if (userSafe == address(0) || vaultAddress == address(0)) {
            revert InvalidParameters();
        }
        
        // Approve vault to spend the received tokens
        IERC20(tokenSent).forceApprove(vaultAddress, amount);
        
        // Deposit into ERC4626 vault
        // Shares are minted directly to user's Safe address on this chain
        uint256 sharesReceived = IERC4626(vaultAddress).deposit(amount, userSafe);
        
        // Verify minimum shares received (slippage protection)
        if (sharesReceived < minSharesOut) revert InsufficientShares();
        
        // Generate unique message ID for tracking
        bytes32 messageId = keccak256(
            abi.encodePacked(
                block.chainid,
                block.number,
                block.timestamp,
                userSafe,
                vaultAddress,
                amount
            )
        );
        
        emit CrossChainDepositComplete(
            userSafe,
            vaultAddress,
            amount,
            sharesReceived,
            messageId
        );
    }
    
    /**
     * @notice Allow or disallow a vault for deposits
     * @dev Only owner can call this
     * @param vaultAddress The vault to configure
     * @param allowed Whether the vault is allowed
     */
    function setVaultAllowed(address vaultAddress, bool allowed) external onlyOwner {
        if (vaultAddress == address(0)) revert InvalidParameters();
        allowedVaults[vaultAddress] = allowed;
        emit VaultAllowed(vaultAddress, allowed);
    }
    
    /**
     * @notice Transfer ownership to a new address
     * @param newOwner The new owner address
     */
    function transferOwnership(address newOwner) external onlyOwner {
        if (newOwner == address(0)) revert InvalidParameters();
        address oldOwner = owner;
        owner = newOwner;
        emit OwnershipTransferred(oldOwner, newOwner);
    }
    
    /**
     * @notice Emergency withdrawal (owner only)
     * @dev Should only be used if tokens get stuck
     * @param token Token to withdraw
     * @param amount Amount to withdraw
     */
    function emergencyWithdraw(address token, uint256 amount) external onlyOwner {
        IERC20(token).safeTransfer(owner, amount);
    }
}
